# Claude OS — .env.example
#
# Copy to `.env` (gitignored). Sensitive secrets go into the OS-Keyring via
# NAPI-RS (see SECURITY.md §3 and ADR-0004), NOT into this file.
#
# All `CLAUDE_OS_*` variables are optional unless flagged "required".
# Defaults are documented inline.

# ============================================================================
# Logging  (per ADR-0013)
# ============================================================================

# Verbose CLI stdout (default: false).
# CLAUDE_OS_VERBOSE=1

# Log level (default: info).
# Options: trace | debug | info | warn | error | fatal | silent
# CLAUDE_OS_LOG_LEVEL=info

# Override logs directory.
# Default: %APPDATA%\claude-os\logs (Win)
#          $XDG_STATE_HOME/claude-os/logs (Linux)
#          ~/Library/Logs/claude-os (macOS)
# CLAUDE_OS_LOGS_DIR=

# ============================================================================
# Sidecar / MCP  (per ADR-0006, ADR-0024)
# ============================================================================

# MCP-probe timeout in milliseconds (default: 5000).
# CLAUDE_OS_MCP_PROBE_TIMEOUT_MS=5000

# Override node-pty binding directory. Development only.
# CLAUDE_OS_NODE_PTY_DIR=

# NOTE: CLAUDE_OS_RPC_NONCE is generated at sidecar spawn by the supervisor.
# Do NOT set it manually — that breaks the nonce-handshake (ADR-0024 §Anhang
# "Trust-Boundary-Mapping").

# ============================================================================
# Anthropic-CLI Auth  (per ADR-0011)
# ============================================================================

# Override the Anthropic-CLI config directory. Used by claude-os for
# multi-profile sandboxing (see ADR-0011 §4).
# Default: %USERPROFILE%\.claude (Win), ~/.claude (Linux/macOS).
# ANTHROPIC_CONFIG_DIR=

# Headless / CI bypass. Set these to skip the file/keychain credential read.
# CLAUDE_CODE_OAUTH_TOKEN=
# CLAUDE_CODE_OAUTH_REFRESH_TOKEN=
# CLAUDE_CODE_OAUTH_SCOPES=

# ============================================================================
# Memory & Vault  (per ADR-0025, ADR-0031)
# ============================================================================

# Path to the Obsidian-Vault root.
# Claude OS expects the layout `<vault>/Claude-OS/workspaces/...` (see
# ADR-0031). Required as soon as the Memory MVP (Phase 2) is in use.
# Example (Win): C:\Users\You\Documents\ObsidianVault
# Example (Mac): /Users/you/Documents/ObsidianVault
# CLAUDE_OS_VAULT_PATH=

# Default active workspace at session start.
# Options: personal | msp-internal | msp-customers/<customer-id>
# Default: personal
# CLAUDE_OS_WORKSPACE=personal

# ============================================================================
# Audit Log  (per SECURITY.md §4)
# ============================================================================

# Override audit-log directory.
# Default: <config>/audit/YYYY-MM/audit.jsonl
# CLAUDE_OS_AUDIT_PATH=
