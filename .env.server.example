# claude-os SERVER deployment — example environment file.
# Copy to `.env` next to `docker-compose.yml` and fill in the secrets.
#
# Generate fresh values with:
#   openssl rand -hex 32

# ---------- REQUIRED ----------

# Bearer token clients use to authenticate against the HTTP API.
# Anyone holding this token has full access to claude-os — treat as
# a password. Rotate via env-restart if compromised.
CLAUDE_OS_AUTH_TOKEN=

# Passphrase for the encrypted secrets file (AES-256-GCM, PBKDF2-SHA-256,
# 600k iterations). Losing it makes stored secrets unrecoverable;
# keep a backup in your password manager.
CLAUDE_OS_SECRETS_PASSPHRASE=

# ---------- OPTIONAL ----------

# Cloudflare Tunnel token — only if the `cloudflared` service in
# docker-compose.yml is enabled. Get from Cloudflare Zero Trust dashboard.
# CF_TUNNEL_TOKEN=

# Log verbosity: trace|debug|info|warn|error. Default: info.
# CLAUDE_OS_LOG_LEVEL=info

# Override the in-container vault path. Default: /data/vault
# CLAUDE_OS_VAULT_PATH=/data/vault

# Override the in-container Anthropic config dir (`claude auth login`
# writes credentials here). Default: /data/anthropic
# ANTHROPIC_CONFIG_DIR=/data/anthropic
