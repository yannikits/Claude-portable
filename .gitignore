# Generiert von setup.bat
bin/node/

# Secrets
.key
.env
.env.local
.env.*.local

# Vault-Inhalt (eigenes Git-Repo)
vault/*
!vault/.gitignore

# Claude-Config: Cache und lokale Daten
config/cache/
config/downloads/
config/file-history/
config/metrics/
config/mcp-health-cache.json
config/mcp-needs-auth-cache.json
config/settings.local.json
config/plugins/cache/

# Node.js / TypeScript build artifacts (Phase 1a+)
node_modules/
dist/
coverage/
*.tsbuildinfo

# Pino-roll log output (local, per ADR-0013)
logs/
*.log

# Husky temporary cache (Phase 1a)
.husky/_/

# Jest cache
.jest-cache/

# ruflo / ruvector local DB artifacts
ruvector.db
ruvector.db-*

# OS / Editor
.DS_Store
Thumbs.db
*.swp

# Windows-DOS-Reserved-Names (vermeidet, dass accidental PowerShell-Redirects wie
# `... > nul` als trackable files in GitHub Desktop "Stage all" landen — siehe
# tasks/lessons.md 2026-05-26)
nul
con
prn
aux
com[1-9]
lpt[1-9]

# Sidecar runtime dirs (created when claude-os runs against the repo root in dev)
inbox/
outbox/

# Claude Code per-machine local settings (convention: *.local.json is never committed)
.claude/settings.local.json
# Claude Code scheduled-task scratch (session-only state)
.claude/scheduled_tasks.json
.claude/scheduled_tasks.lock

# claude-mem / agentdb runtime state (per-machine, local-only)
agentdb.rvf
agentdb.rvf.lock

# graphify skill output (per-machine, local-only)
graphify-out/
.graphify_step_ast.py
