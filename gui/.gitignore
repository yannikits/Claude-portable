# Rust build artefacts (Cargo target dir — can reach 1GB+)
src-tauri/target/
src-tauri/gen/schemas/

# Frontend build output
dist/
node_modules/

# Tauri-generated bundle output
src-tauri/bundle/

# Sidecar binary (per-arch, built by scripts/build-sidecar.*)
src-tauri/binaries/

# Mobile icon variants (regenerated by `npx tauri icon` — v1 doesn't ship mobile)
src-tauri/icons/ios/
src-tauri/icons/android/
