{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for claude-os shell. Scopes shell:execute to the bundled sidecar only.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/claude-os-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "updater:default"
  ]
}
