{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "claude-os",
  "version": "1.7.4",
  "identifier": "net.iteenschmiede.claude-os",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "claude-os",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/claude-os-sidecar"],
    "resources": ["binaries/node-pty/**/*"],
    "category": "DeveloperTool",
    "shortDescription": "claude-os desktop shell",
    "longDescription": "Tauri shell for claude-os — vault sync, catalog, agent runs, secrets.",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/yannikits/Claude-portable/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE-WITH-BASE64-PUBKEY-FROM-tauri-signer-generate",
      "dialog": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
