{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "claude-os",
  "version": "0.1.0-alpha.5",
  "identifier": "net.iteenschmiede.claude-os",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "claude-os",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "appimage"],
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "claude-os desktop shell",
    "longDescription": "Tauri shell for claude-os — vault sync, catalog, agent runs, secrets."
  }
}
